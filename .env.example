# Example Environment Variables for Guardia AI
# Copy this file to .env and customize

# ================================
# Redis Configuration
# ================================
REDIS_URL=redis://redis:6379

# ================================
# MinIO (Object Storage)
# ================================
MINIO_ROOT_USER=guardia
MINIO_ROOT_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_NOW
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=guardia-clips

# ================================
# PostgreSQL (Cloud API)
# ================================
POSTGRES_DB=guardia
POSTGRES_USER=guardia
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD_NOW

# ================================
# JWT Authentication
# ================================
JWT_SECRET=CHANGE_THIS_TO_RANDOM_256BIT_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ================================
# Camera Manager (NEW)
# ================================
MAX_CAMERAS=3
DROIDCAM_ENABLED=true
DROIDCAM_DEFAULT_PORT=4747
WEBCAM_DEVICE_ID=0
DEFAULT_FPS=30
DEFAULT_RESOLUTION_WIDTH=640
DEFAULT_RESOLUTION_HEIGHT=480
CAMERA_MANAGER_ZMQ_PORT=5556

# ================================
# Camera Ingest (Legacy)
# ================================
CAMERA_INGEST_ZMQ_PORT=5555
CAMERA_INGEST_LOG_LEVEL=INFO
CONFIG_PATH=/app/config/cameras.yaml

# ================================
# Edge Computing (NEW)
# ================================
MOTION_THRESHOLD=0.3
JPEG_QUALITY=75
FRAME_SKIP=2
LOCAL_STORAGE_ENABLED=true
LOCAL_STORAGE_PATH=/app/storage
MAX_LOCAL_STORAGE_GB=50
CLOUD_SYNC_ENABLED=true
EDGE_COMPUTE_ZMQ_PORT=5557

# ================================
# Security Fusion (NEW)
# ================================
OWNER_PROTECTION_MODE=true
ANOMALY_THRESHOLD=0.7
FACE_RECOGNITION_ENABLED=true
FACE_CONFIDENCE_THRESHOLD=0.8
TRACKING_MAX_AGE=30
TRACKING_MIN_HITS=3
FACE_DB_PATH=/app/data/faces

# ================================
# Preprocessing
# ================================
FACE_BLUR_ENABLED=true
TARGET_WIDTH=640
TARGET_HEIGHT=480
PREPROCESSING_ZMQ_PORT=5556

# ================================
# Model Services
# ================================
# SkeleGNN
SKELEGNN_MODEL_PATH=/app/weights/skelegnn.onnx
SKELEGNN_CONFIDENCE_THRESHOLD=0.5

# MotionStream
MOTIONSTREAM_MODEL_PATH=/app/weights/motionstream.onnx
MOTIONSTREAM_ANOMALY_THRESHOLD=0.7

# MoodTiny
MOODTINY_MODEL_PATH=/app/weights/moodtiny.onnx
MOODTINY_PRIVACY_MODE=true
MOODTINY_CONFIDENCE_THRESHOLD=0.6

# ================================
# FusionController
# ================================
FUSION_DB_PATH=/app/data/guardia.db
FUSION_ZMQ_PORT=5560

# ================================
# User Management (NEW)
# ================================
USER_MANAGEMENT_PORT=8012
MAX_FAMILY_MEMBERS=10

# ================================
# Alerting
# ================================
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/alerts
MIN_ALERT_SEVERITY=medium
ALERTS_PORT=8007
PUSH_NOTIFICATIONS_ENABLED=false
ALERT_COOLDOWN_SECONDS=60

# ================================
# API Service
# ================================
API_PORT=8000
DATABASE_URL=postgresql://guardia:CHANGE_THIS_DB_PASSWORD_NOW@postgres:5432/guardia
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ================================
# Web Dashboard
# ================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8007/ws

# ================================
# Logging & Monitoring
# ================================
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# ================================
# GPU Configuration (Optional)
# ================================
USE_GPU=false
CUDA_DEVICE=0

# ================================
# Development
# ================================
# Uncomment for development mode
# NODE_ENV=development
# DEBUG=true
