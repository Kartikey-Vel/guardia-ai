# Backend environment template — copy to .env and fill in your keys
# ==========================================================================

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# Google Gemini Flash (FREE 1.5k req/day) — https://ai.google.dev/
GEMINI_API_KEY=

# Groq LLM (FREE 14k req/day) — https://console.groq.com/
GROQ_API_KEY=

# HuggingFace (optional, for audio classification) — https://huggingface.co/
HUGGINGFACE_API_KEY=

# ── Runtime Settings ──────────────────────────────────────────────────────────
ALERT_THRESHOLD=5
ANALYSIS_INTERVAL_FRAMES=30
DATABASE_URL=sqlite:///./guardia.db

# ── YOLO Settings ─────────────────────────────────────────────────────────────
YOLO_ENABLED=true
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=20

# ── Server Config ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── AI Model Names (can override here) ────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama3-8b-8192

# ── Demo Mode (used when no camera is connected) ──────────────────────────────
DEMO_MODE=false
DEMO_INTERVAL_SECONDS=10
