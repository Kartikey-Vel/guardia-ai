# API Server settings
DEBUG_MODE=False
HOST=0.0.0.0
PORT=8000

# Security settings
SECRET_KEY=your_super_secure_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MongoDB settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=guardia_db

# AI Settings
MOTION_DETECTION_THRESHOLD=0.6
ANOMALY_DETECTION_THRESHOLD=0.7
WEAPON_DETECTION_THRESHOLD=0.8
GUNSHOT_DETECTION_THRESHOLD=0.75
SCREAM_DETECTION_THRESHOLD=0.65

# Alert settings
ALERT_EMAIL=security@example.com
SMS_API_KEY=your_sms_api_key_here

# Video sources (comma-separated)
VIDEO_SOURCES=rtsp://example.com/camera1,rtsp://example.com/camera2
