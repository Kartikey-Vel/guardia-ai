# Backend environment template

# AI keys
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Runtime settings
ALERT_THRESHOLD=5
ANALYSIS_INTERVAL_FRAMES=30
DATABASE_URL=sqlite:///./guardia.db

# YOLO (Ultralytics) settings
YOLO_ENABLED=true
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45
YOLO_MAX_DETECTIONS=20

# Optional service config
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
