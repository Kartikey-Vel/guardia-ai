# Version control
.git/
.gitignore
.svn/
.hg/

# Python cache and artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
.Python

# Development and IDE files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Build and output directories
dist/
build/
out/
debug/

# Test directories and files
test/
tests/
*_test.go

# Logs and temporary files
*.log
tmp/
temp/
*.tmp

# Environment and secret files
.env*
*.env
*.pem
*.key
*.crt
config.local.*
*.local.yml
.local/
local/

# Documentation (keep essential ones)
*.md
docs/

# Docker files (exclude from image)
Dockerfile*
docker-compose*
compose.yaml*
*.bak*

# Backup files
*.bak
*.backup

# Project-specific data directories (will be mounted as volumes)
data/
detected/
encodings/
faces/
images/
logs/

# Virtual environments
.venv/
venv/
env/

# Node.js (if present)
node_modules/
npm-debug.log
yarn-debug.log

# Miscellaneous
*.minimal
run.sh
